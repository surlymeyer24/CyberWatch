{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "CyberWatch.Service (Debug)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-service",
      "program": "${workspaceFolder}/CyberWatch.Service/bin/Debug/net8.0/CyberWatch.Service.exe",
      "args": [],
      "cwd": "${workspaceFolder}/CyberWatch.Service/bin/Debug/net8.0",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "env": {
        "DOTNET_ENVIRONMENT": "Development"
      }
    },
    {
      "name": "CyberWatch.UserAgent (Debug)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-useragent",
      "program": "${workspaceFolder}/CyberWatch.UserAgent/bin/Debug/net8.0-windows10.0.19041.0/CyberWatch.UserAgent.exe",
      "args": [],
      "cwd": "${workspaceFolder}/CyberWatch.UserAgent/bin/Debug/net8.0-windows10.0.19041.0",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "env": {
        "DOTNET_ENVIRONMENT": "Development"
      }
    }
  ]
}
